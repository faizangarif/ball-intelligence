# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ballintelligence?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Sports Data Provider: "mock" or "api"
SPORTS_DATA_PROVIDER=mock

# Optional: OpenAI for AI Scorecast commentary (falls back to templates if not set)
OPENAI_API_KEY=

# Optional: Redis for caching
REDIS_URL=
